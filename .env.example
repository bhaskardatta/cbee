# cbee Phase 2 — frontend env template
# Copy to `.env` and fill in. Vite inlines `VITE_*` vars at build time
# so anything here ends up in the client bundle — only put PUBLIC values.

# Supabase project (anon / publishable key is safe in client code)
VITE_SUPABASE_PROJECT_ID="gjaoevysppponsawrjha"
VITE_SUPABASE_URL="https://gjaoevysppponsawrjha.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="<paste anon key from Supabase dashboard → Project Settings → API>"
