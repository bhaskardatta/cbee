# =============================================================
#  cbee Phase 2 — gitignore
# =============================================================

# ---- JS / Node ----
node_modules/
dist/
dist-ssr/
*.tsbuildinfo
*.local

# ---- Logs ----
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ---- Editor / IDE ----
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store

# ---- Capacitor: synced web assets land in native folders ----
android/app/src/main/assets/public/
android/app/src/main/assets/capacitor.config.json
android/app/src/main/assets/capacitor.plugins.json
ios/App/App/public/
ios/App/App/capacitor.config.json
ios/App/App/capacitor.plugins.json

# ---- Android: gradle + build artifacts ----
android/.gradle/
android/.idea/
android/build/
android/app/build/
android/app/release/
android/captures/
android/local.properties
*.apk
*.aab

# ---- Android: keystores (release signing — kept out of repo) ----
*.jks
*.keystore
key.properties

# ---- Android: push notifications config (not yet wired) ----
# Drop your Firebase google-services.json into android/app/ to enable FCM.
android/app/google-services.json

# ---- iOS: build + dependencies ----
ios/App/build/
ios/App/Pods/
ios/App/Podfile.lock
ios/DerivedData/
ios/App/App.xcworkspace/xcuserdata/
ios/App/App.xcodeproj/xcuserdata/
ios/App/App.xcodeproj/project.xcworkspace/xcuserdata/
*.xcuserstate
*.mobileprovision

# ---- macOS / system ----
.DS_Store
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ---- Misc lockfiles we don't use ----
bun.lockb
yarn.lock
pnpm-lock.yaml

# ---- Test + debug artifacts ----
/tmp/
*.har
coverage/
.nyc_output/

# ---- Personal dev notes (keep .env.example tracked) ----
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
